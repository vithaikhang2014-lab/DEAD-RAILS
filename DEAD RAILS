-- Helper: Slider
local function addSlider(text, minVal, maxVal, defaultVal, callback)
    local sliderFrame = Instance.new("Frame")
    sliderFrame.Size = UDim2.new(1, 0, 0, 70)
    sliderFrame.BackgroundTransparency = 1
    sliderFrame.Parent = scrollFrame
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 22)
    label.BackgroundTransparency = 1
    label.Text = text .. ": " .. tostring(defaultVal)
    label.TextColor3 = Color3.fromRGB(210, 210, 250)
    label.TextSize = 13
    label.Font = Enum.Font.Gotham
    label.Parent = sliderFrame
    
    local sliderBg = Instance.new("Frame")
    sliderBg.Size = UDim2.new(1, -20, 0, 6)
    sliderBg.Position = UDim2.new(0, 10, 0, 38)
    sliderBg.BackgroundColor3 = Color3.fromRGB(55, 55, 75)
    sliderBg.BorderSizePixel = 0
    sliderBg.Parent = sliderFrame
    local sliderCorner = Instance.new("UICorner", sliderBg)
    sliderCorner.CornerRadius = UDim.new(1, 0)
    
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((defaultVal - minVal) / (maxVal - minVal), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(255, 160, 70)
    fill.BorderSizePixel = 0
    fill.Parent = sliderBg
    local fillCorner = Instance.new("UICorner", fill)
    fillCorner.CornerRadius = UDim.new(1, 0)
    
    local grab = Instance.new("TextButton")
    grab.Size = UDim2.new(0, 18, 0, 18)
    grab.Position = UDim2.new((defaultVal - minVal) / (maxVal - minVal), -9, 0, -6)
    grab.BackgroundColor3 = Color3.fromRGB(255, 200, 100)
    grab.Text = ""
    grab.Parent = sliderBg
    local grabCorner = Instance.new("UICorner", grab)
    grabCorner.CornerRadius = UDim.new(1, 0)
    
    local value = defaultVal
    local dragging = false
    grab.MouseButton1Down:Connect(function() dragging = true end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    grab.MouseMoved:Connect(function()
        if dragging then
            local mousePos = Mouse.X
            local sliderPos = sliderBg.AbsolutePosition.X
            local width = sliderBg.AbsoluteSize.X
            local percent = math.clamp((mousePos - sliderPos) / width, 0, 1)
            local newVal = minVal + (maxVal - minVal) * percent
            value = math.floor(newVal)
            fill.Size = UDim2.new(percent, 0, 1, 0)
            grab.Position = UDim2.new(percent, -9, 0, -6)
            label.Text = text .. ": " .. tostring(value)
            if callback then callback(value) end
        end
    end)
end

-- ========== TÍNH NĂNG DEAD RAILS ==========
local settings = {
    esp = false,
    monsterDetect = false,
    bringItems = false,
    autoBonds = false,
    autoMoney = false,
    walkSpeed = 16
}

local espInstances = {}

local function clearESP()
    for _, v in pairs(espInstances) do
        if v and v.Parent then v:Destroy() end
    end
    espInstances = {}
    for _, v in pairs(Workspace:GetDescendants()) do
        if v.Name == "ESP_Tornado" then v:Destroy() end
    end
end

local function updateESP()
    clearESP()
    if not settings.esp then return end
    task.spawn(function()
        while settings.esp and task.wait(0.3) do
            for _, model in pairs(Workspace:GetDescendants()) do
                if model:IsA("Model") and model:FindFirstChild("Humanoid") and model ~= LocalPlayer.Character then
                    if not model:FindFirstChild("ESP_Tornado") then
                        local bill = Instance.new("BillboardGui")
                        bill.Name = "ESP_Tornado"
                        bill.Size = UDim2.new(0, 200, 0, 40)
                        bill.Adornee = model
                        bill.AlwaysOnTop = true
                        bill.Parent = model
                        table.insert(espInstances, bill)
                        
                        local nameTag = Instance.new("TextLabel", bill)
                        nameTag.Size = UDim2.new(1, 0, 1, 0)
                        nameTag.BackgroundTransparency = 1
                        nameTag.Text = model.Name
                        nameTag.TextColor3 = Color3.fromRGB(255, 100, 100)
                        nameTag.TextStrokeTransparency = 0.2
                        nameTag.TextScaled = true
                    end
                end
            end
        end
    end)
end

local function monsterDetectLoop()
    task.spawn(function()
        while settings.monsterDetect and task.wait(1) do
            local nearestDist = math.huge
            local nearestName = ""
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local charPos = LocalPlayer.Character.HumanoidRootPart.Position
                for _, model in pairs(Workspace:GetDescendants()) do
                    if model:IsA("Model") and model:FindFirstChild("Humanoid") and model ~= LocalPlayer.Character then
                        local part = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Head")
                        if part then
                            local dist = (part.Position - charPos).Magnitude
                            if dist < nearestDist and dist < 50 then
                                nearestDist = dist
                                nearestName = model.Name
                            end
                        end
                    end
                end
            end
            if nearestDist < 30 then
                welcomeLabel.Text = "⚠️ MONSTER: " .. nearestName .. " (" .. math.floor(nearestDist) .. "m) ⚠️"
                welcomeLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
            else
                welcomeLabel.Text = "✨ Welcome, " .. LocalPlayer.Name .. "! ✨"
                welcomeLabel.TextColor3 = Color3.fromRGB(180, 210, 255)
            end
        end
    end)
end

local function autoCollectLoop()
    task.spawn(function()
        while task.wait(0.5) do
            if settings.autoBonds or settings.autoMoney then
                for _, obj in pairs(Workspace:GetDescendants()) do
                    if obj:IsA("BasePart") or (obj:IsA("Model") and obj.PrimaryPart) then
                        local nameLow = string.lower(obj.Name)
                        local shouldCollect = false
                        if settings.autoBonds and (nameLow:find("bond") or nameLow:find("token") or nameLow:find("coin")) then
                            shouldCollect = true
                        end
                        if settings.autoMoney and (nameLow:find("money") or nameLow:find("bag") or nameLow:find("cash")) then
                            shouldCollect = true
                        end
                        if shouldCollect and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                            local targetPos = obj:IsA("BasePart") and obj.Position or (obj.PrimaryPart and obj.PrimaryPart.Position) or nil
                            if targetPos then
                                LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(targetPos)
                                task.wait(0.1)
                            end
                        end
                    end
                end
            end
        end
    end)
end

local function bringItemsLoop()
    task.spawn(function()
        while settings.bringItems and task.wait(0.8) do
            for _, obj in pairs(Workspace:GetDescendants()) do
                if (obj:IsA("BasePart") or obj:IsA("Model")) and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    local nameLow = string.lower(obj.Name)
                    if nameLow:find("chest") or nameLow:find("item") or nameLow:find("drop") or nameLow:find("supply") then
                        local targetCFrame = obj:IsA("BasePart") and obj.CFrame or (obj.PrimaryPart and obj.PrimaryPart.CFrame) or nil
                        if targetCFrame then
                            obj.CFrame = LocalPlayer.Character.HumanoidRootPart.CFrame + Vector3.new(0, 1, 0)
                            task.wait(0.1)
                        end
                    end
                end
            end
        end
    end)
end

local function applySpeed(speed)
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = speed
    end
    LocalPlayer.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        char:FindFirstChild("Humanoid").WalkSpeed = speed
    end)
end

